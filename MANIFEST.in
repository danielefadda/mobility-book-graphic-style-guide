include README*.md
include LICENSE
include pyproject.toml
include requirements.txt

# Include fonts
recursive-include mobility_book_style/fonts *.ttf *.otf *.txt

# Include examples but not outputs
recursive-include examples *.ipynb *.py
recursive-exclude examples/outputs *

# Include docs
recursive-include docs *.md *.html *.css *.js *.xml

# Exclude build artifacts and cache
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
